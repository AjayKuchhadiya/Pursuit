# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Database (Alembic migrations) ────────────────────────────────────────────
# Find in Supabase: Project Settings → Database → Connection string → URI
# Use the direct connection (port 5432), not the pooler
DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# ── Meta WhatsApp Business Cloud API ─────────────────────────────────────────
META_ACCESS_TOKEN=<permanent-page-or-system-user-token>
META_PHONE_NUMBER_ID=<whatsapp-phone-number-id>
META_WHATSAPP_API_VERSION=v19.0
# Arbitrary string you set in the Meta App Dashboard → Webhooks → Verify Token
META_WEBHOOK_VERIFY_TOKEN=change-me-webhook-verify-token

# ── Cron security ─────────────────────────────────────────────────────────────
# Store this same value as a GitHub Actions secret called CRON_SECRET
CRON_SECRET=change-me-cron-secret

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development   # development | production
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app


# NGROK: 
# Get-Process ngrok -ErrorAction SilentlyContinue | Stop-Process -Force; Start-Sleep 2; ngrok http 8000 --request-header-add "ngrok-skip-browser-warning:true"